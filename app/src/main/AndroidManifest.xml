<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.READ_PHONE_STATE"/>
    <uses-permission android:name="android.permission.READ_CALL_LOG"/>
    <uses-permission android:name="android.permission.CALL_PHONE"/>
    <uses-permission android:name="android.permission.MANAGE_OWN_CALLS"/>
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS"/>
    <!-- read soundtrack files pushed via adb to /sdcard (Android 13+ scoped storage) -->
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO"/>
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_PHONE_CALL"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <!-- signature|privileged: NOT grantable on a stock device. Declared so a future
         rooted / priv-app placement enables AudioSource.VOICE_CALL with no code change. -->
    <uses-permission android:name="android.permission.CAPTURE_AUDIO_OUTPUT"
        tools:ignore="ProtectedPermissions"/>

    <application
        android:name=".CallBotApp"
        android:allowBackup="false"
        android:label="CallBot"
        android:icon="@android:drawable/sym_action_call"
        android:theme="@android:style/Theme.Material.Light">

        <!-- Default-dialer eligibility: must declare ACTION_DIAL activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.DIAL"/>
                <category android:name="android.intent.category.DEFAULT"/>
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.DIAL"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <data android:scheme="tel"/>
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <action android:name="android.intent.action.DIAL"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="tel"/>
            </intent-filter>
        </activity>

        <!-- In-call UI: caller id, timer, answer/hangup/mute/speaker/DTMF/play/record -->
        <activity
            android:name=".InCallActivity"
            android:exported="true"
            android:launchMode="singleInstance"
            android:showOnLockScreen="true"
            android:showWhenLocked="true"
            android:turnScreenOn="true"/>

        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:label="CallBot Settings"/>

        <!-- InCallService — Telecom binds this when we are the default dialer -->
        <service
            android:name=".CallBotInCallService"
            android:exported="true"
            android:permission="android.permission.BIND_INCALL_SERVICE">
            <meta-data
                android:name="android.telecom.IN_CALL_SERVICE_UI"
                android:value="true"/>
            <intent-filter>
                <action android:name="android.telecom.InCallService"/>
            </intent-filter>
        </service>

        <!-- Foreground service (microphone) hosting the call recorder -->
        <service
            android:name=".RecorderService"
            android:exported="false"
            android:foregroundServiceType="microphone"/>

        <!-- ADB command surface: am broadcast -p com.essence.callbot -a com.essence.callbot.CMD -->
        <receiver
            android:name=".CommandReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.essence.callbot.CMD"/>
            </intent-filter>
        </receiver>

    </application>
</manifest>
